" IdeaVim configuration
" Options aligned with lua/basic.lua; mappings with lua/keybindings.lua / vscode_neovim
" Neovim-first: conflicting IDEA actions use alternate prefixes (see README)

" =============================================================================
" 1. Options (from lua/basic.lua, IdeaVim-supported)
" =============================================================================

" Encoding (basic.lua: vim.g.encoding / fileencoding)
set encoding=utf-8
set fileencoding=utf-8

" Clipboard: unnamed + IDE paste (basic.lua: clipboard=unnamed)
set clipboard=unnamed,ideaput

" Terminal color compat (legacy)
let &t_ut=' '

set autoread
set hidden
set backup=false
set writebackup=false
set swapfile=false

" Line numbers & cursor (basic.lua)
set number
set relativenumber
set cursorline
set colorcolumn=80

" Indent: 4 spaces, expand tab (basic.lua)
set expandtab
set tabstop=4
set shiftwidth=4
set softtabstop=4
set autoindent
set smartindent
set shiftround

" Whitespace display (basic.lua: list / listchars)
set list
set listchars=eol:↵,tab:>~

" Scroll context (basic.lua: scrolloff / sidescrolloff)
set scrolloff=8
set sidescrolloff=8

" Mapping timeout (IDE-friendly)
set ttimeoutlen=0
set notimeout

" basic.lua effective wrap: wo.wrap=false
set nowrap

set whichwrap=b,s,<,>,[,],h,l
set tw=80

" Folding (IDEA editor)
set foldmethod=indent
set foldlevel=99
set foldenable
set formatoptions-=tc

set splitright
set splitbelow

" basic.lua: showmode off; mouse not enabled in basic / vscode embed
set noshowmode

set showcmd
set cmdheight=2
set wildmenu
set shortmess+=c
set completeopt=menu,menuone,noselect,noinsert
set pumheight=10

" Search (basic.lua)
set ignorecase
set smartcase
set hlsearch
set incsearch

set ttyfast
set lazyredraw
set visualbell

" Restore cursor on reopen (basic.lua autocmd)
au BufReadPost * if line("'\"") > 1 && line("'\"") <= line("$") | exe "normal! g'\"" | endif

" =============================================================================
" 2. Vim mappings (lua/keybindings.lua / vscode_neovim_init.lua)
" =============================================================================

let mapleader=" "

" Save / quit / reload
map S :w<CR>
map Q :q<CR>
map R :source ~/.ideavimrc<CR>
map <LEADER>rc :e ~/.ideavimrc<CR>

" Insert mode entry (h -> i)
noremap h i
noremap H I
vnoremap h i
vnoremap H I

nnoremap Y y$

" Indent
nnoremap < <<
nnoremap > >>

" Search
noremap n nzz
noremap N Nzz
noremap <LEADER><CR> :nohlsearch<CR>
noremap <LEADER>dw /\(\<\w\+\>\)\_s*\1

" Fold (<leader>o reserved for za; IDEA file structure -> <leader>fo)
map <silent> <LEADER>o za

" Cursor: ijkl layout
noremap <silent> i k
noremap <silent> k j
noremap <silent> j h
noremap <silent> l l
vnoremap <silent> i k
vnoremap <silent> k j
vnoremap <silent> j h
vnoremap <silent> l l

noremap <silent> I 5k
noremap <silent> K 5j
noremap <silent> J b
noremap <silent> L w
noremap <silent> E $
vnoremap <silent> I 5k
vnoremap <silent> K 5j
vnoremap <silent> J b
vnoremap <silent> L w

noremap <LEADER>mi 5<C-y>
noremap <LEADER>mk 5<C-e>

" Window focus (<leader> i/j/k/l; IDEA PrevSplitter -> <leader>pi)
map <LEADER>i <C-w>k
map <LEADER>k <C-w>j
map <LEADER>j <C-w>h
map <LEADER>l <C-w>l

noremap s <nop>

noremap si :set nosplitbelow<CR>:split<CR>:set splitbelow<CR>
noremap sk :set splitbelow<CR>:split<CR>
noremap sj :set nosplitright<CR>:vsplit<CR>:set splitright<CR>
noremap sl :set splitright<CR>:vsplit<CR>

nnoremap <Up> :resize -5<CR>
nnoremap <Down> :resize +5<CR>
nnoremap <Left> :vertical resize -5<CR>
nnoremap <Right> :vertical resize +5<CR>

map sh <C-w>t<C-w>K
map sv <C-w>t<C-w>H
noremap srh <C-w>b<C-w>K
noremap srv <C-w>b<C-w>H

" Close editor tab (vscode_neovim: leader+q; not vim :q split)
map <LEADER>q <Action>(CloseEditor)

noremap <LEADER>sc ~

" Navigation stack (keybindings.lua)
noremap <A-[> <C-i>
noremap <A-]> <C-o>

" Visual indent keeps selection
xnoremap < <gv
xnoremap > >gv

" =============================================================================
" 3. IDEA Actions (non-conflicting / migrated prefixes)
" =============================================================================
" Migrated (Neovim-first):
"   FileStructurePopup     <leader>fo  (was <leader>o)
"   PrevSplitter           <leader>pi  (was <leader>i)
"   SelectInProjectView    <leader>ps  (was <leader>s; also <leader>pw)

" Debug / refactor / IDE
map <leader>d <Action>(Debug)
map <leader>r <Action>(RenameElement)
map <leader>RR <Action>(Refactorings.QuickListPopupAction)
map <leader>c <Action>(Stop)
map <leader>z <Action>(ToggleDistractionFreeMode)
map <leader>oi <Action>(OptimizeImports)
map <leader>h <Action>(Vcs.ShowTabbedFileHistory)
map <S-Space> <Action>(GotoNextError)
map <leader>ee <Action>(ShowErrorDescription)
map <leader>hh <Action>(QuickImplementations)
map <leader>hj <Action>(ShowHoverInfo)

" Breakpoints
map <leader>ub <Action>(ToggleLineBreakpoint)
map <leader>us <Action>(ViewBreakpoints)
map <leader>ur <Action>(Debugger.RemoveAllBreakpoints)

" Comments
map <leader>cl <Action>(CommentByLineComment)
map <leader>cb <Action>(CommentByBlockComment)

" Ace
map fl <Action>(AceLineAction)

" Navigation & structure
map <leader>hu <Action>(HighlightUsagesInFile)
map <leader>rl <Action>(RecentLocations)
map gy <Action>(RecentChangedFiles)
map <leader>sh <Action>(LocalHistory.ShowHistory)
map <leader>m <Action>(ShowIntentionActions)
map <leader>fo <Action>(FileStructurePopup)
map <leader>ps <Action>(SelectInProjectView)
map <leader>pw <Action>(SelectInProjectView)
map <leader>rt <Action>(RunContextGroup)
map gh <Action>(GotoDeclaration)
map <leader>so <Action>(SelectAllOccurrences)

" Copy whole file
nmap <C-a> ggVG"+y

" Code navigation (g-prefix; normal k/j still remapped above)
map gf {
map gj }
map gd <Action>(MethodUp)
map gk <Action>(MethodDown)
map ge <Action>(GotoNextError)
map gE <Action>(GotoPreviousError)
map gs <Action>(JumpToLastChange)
map gl <Action>(JumpToNextChange)
map ga <Action>(VcsShowNextChangeMarker)
map gø <Action>(VcsShowPrevChangeMarker)
map gn <Action>(GotoNextElementUnderCaretUsage)
map gN <Action>(GotoPrevElementUnderCaretUsage)

" Splitters (migrated from <leader>i)
nmap <leader>pi <Action>(PrevSplitter)
nmap <C-v> <Action>(SplitVertically)

" History navigation
nmap <C-o> <Action>(Back)
nmap <C-i> <Action>(Forward)
map g<C-o> <C-o>
map g<C-i> <C-i>

" Close editors
map <leader>Q <Action>(CloseAllEditors)
map <leader>w <Action>(CloseAllEditorsButActive)

" IDEA shortcuts restored
map <C-n> <Action>(SearchEverywhere)
map <leader>gg <Action>(GotoFile)
map <C-b> <Action>(ShowUsages)
map <C-s> <Action>(SaveAll)
map <C-c> <Action>(GotoImplementation)

" Run / debug
map <leader>cg <Action>(ChooseRunConfiguration)
map <leader>dg <Action>(ChooseDebugConfiguration)
map <leader>1 <Action>(Run)
map <leader>2 <Action>(Debug)
map <leader>0 <Action>(Stop)
